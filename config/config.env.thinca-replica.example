# ThinCA replica — joins an existing topology with IPAThinCA backend
# Can join a Dogtag-based primary (mixed CA topology)
#
# Copy and edit:
#   cp config/config.env.thinca-replica.example config.env.thinca

IDM_ROLE=replica
IDM_DOMAIN=test.example.com
IDM_REALM=TEST.EXAMPLE.COM
IDM_ADMIN_PASSWORD=CHANGEME
IDM_DS_PASSWORD=CHANGEME
IDM_HOSTNAME=idm4.test.example.com
IDM_SETUP_DNS=yes
IDM_DNS_FORWARDER=8.8.8.8
IDM_NO_REVERSE=yes
IDM_SERVER_FQDN=idm1.test.example.com
IDM_SERVER_IP=192.168.140.101
IDM_REPLICA_SETUP_DNS=yes
IDM_REPLICA_SETUP_CA=yes
IDM_SKIP_CONNCHECK=no
IDM_USE_THINCA=yes
