# idm-image-mode deployment configuration
# Copy to config.env and edit before deploying:
#   cp config/config.env.example config.env

# ── Role ─────────────────────────────────────────────────────────────
# Which type of IdM node to deploy
IDM_ROLE=primary           # primary | replica | client

# ── Domain ───────────────────────────────────────────────────────────
IDM_DOMAIN=test.example.com
IDM_REALM=TEST.EXAMPLE.COM

# ── Credentials ──────────────────────────────────────────────────────
IDM_ADMIN_PASSWORD=Secret123!
IDM_DS_PASSWORD=Secret123!

# ── Network ──────────────────────────────────────────────────────────
# Hostname for this node (auto-detected from system hostname if empty)
IDM_HOSTNAME=

# ── Primary Server Options ───────────────────────────────────────────
IDM_SETUP_DNS=yes
IDM_DNS_FORWARDER=8.8.8.8
IDM_NO_REVERSE=yes
IDM_SETUP_ADTRUST=no

# ── Replica / Client Options ────────────────────────────────────────
# FQDN and IP of the primary server to enroll against
IDM_SERVER_FQDN=idm1.test.example.com
IDM_SERVER_IP=192.168.140.101

# ── Replica-Specific ────────────────────────────────────────────────
IDM_REPLICA_SETUP_DNS=yes
IDM_REPLICA_SETUP_CA=yes
