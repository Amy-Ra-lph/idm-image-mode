# ThinCA primary server — standalone IPAThinCA domain
# Lightweight Python CA, no Dogtag/Java/Tomcat
#
# Copy and edit:
#   cp config/config.env.thinca-primary.example config.env.thinca-primary

IDM_ROLE=primary
IDM_DOMAIN=thinca.example.com
IDM_REALM=THINCA.EXAMPLE.COM
IDM_ADMIN_PASSWORD=CHANGEME
IDM_DS_PASSWORD=CHANGEME
IDM_HOSTNAME=thinca1.thinca.example.com
IDM_SETUP_DNS=yes
IDM_DNS_FORWARDER=8.8.8.8
IDM_NO_REVERSE=yes
IDM_USE_THINCA=yes
